<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://poste.it/anc/flowable/pratica">

  <!--
    Processo ANC - Gestione Pratica di Blocco Carta
    ================================================
    Questo processo governa il ciclo di vita di ogni pratica ANC.
    E' avviato da BpmPracticeInboundService.openPractice() con:
      - businessKey = numPratica
      - variabili: numPratica, canale, cfCliente, practiceId

    Stati pratica guidati dal processo:
      APERTA → IN_LAVORAZIONE → IN_ATTESA_CONFERMA_BPM → CHIUSA_OK / CHIUSA_KO

    NOTA: quando si sostituira' Flowable con Cogito, questo file BPMN
    verra' importato nel motore Cogito e il startProcessInstanceByKey
    nel backend verra' sostituito con una chiamata HTTP a Cogito.
  -->

  <process id="anc.pratica" name="ANC - Gestione Pratica" isExecutable="true">

    <!-- ===== START ===== -->
    <startEvent id="start" name="Pratica Aperta"/>

    <sequenceFlow id="flow_start_to_lavorazione" sourceRef="start" targetRef="task_lavorazione"/>

    <!-- ===== LAVORAZIONE OPERATORE ===== -->
    <userTask id="task_lavorazione" name="Lavorazione Pratica"
              flowable:candidateGroups="GRUPPO_OPERATORE_ANC"
              flowable:formKey="anc-lavorazione">
      <documentation>
        L'operatore ANC verifica la documentazione, compila la checklist
        e invia la pratica alla conferma BPM.
      </documentation>
    </userTask>

    <sequenceFlow id="flow_lavorazione_to_attesa" sourceRef="task_lavorazione" targetRef="task_supervisione"/>

    <!-- ===== SUPERVISIONE ===== -->
    <userTask id="task_supervisione" name="Supervisione"
              flowable:candidateGroups="SUPERVISORE_ANC"
              flowable:formKey="anc-supervisione">
      <documentation>
        Il supervisore ANC controlla la pratica lavorata e la approva o respinge.
      </documentation>
    </userTask>

    <!-- Gateway esito supervisione -->
    <sequenceFlow id="flow_supervisione_to_gw" sourceRef="task_supervisione" targetRef="gw_esito"/>

    <exclusiveGateway id="gw_esito" name="Esito Supervisione"/>

    <sequenceFlow id="flow_esito_ok" sourceRef="gw_esito" targetRef="end_ok">
      <conditionExpression xsi:type="tFormalExpression">${esito == 'OK'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_esito_ko" sourceRef="gw_esito" targetRef="end_ko">
      <conditionExpression xsi:type="tFormalExpression">${esito == 'KO'}</conditionExpression>
    </sequenceFlow>

    <!-- ===== END EVENTS ===== -->
    <endEvent id="end_ok" name="Chiusa OK"/>
    <endEvent id="end_ko" name="Chiusa KO"/>

  </process>

</definitions>
