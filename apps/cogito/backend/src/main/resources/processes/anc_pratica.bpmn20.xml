<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:drools="http://www.jboss.org/drools"
             targetNamespace="http://poste.it/anc/kogito/pratica">

  <!--
    Processo ANC - Gestione Pratica di Blocco Carta (Kogito)
    =========================================================
    Processo BPMN 2.0 standard, compilato a Java a compile-time dal kogito-maven-plugin.
    L'ID del processo ("anc_pratica") diventa il nome del bean Spring generato da Kogito.
    NOTA: Kogito non supporta dot (".") nell'ID BPMN — deve essere un identificatore Java valido.

    Avviato da BpmPracticeInboundService via KogitoBpmEngineAdapter.startProcess("anc_pratica", ...)

    Variabili di processo: numPratica, canale, cfCliente, practiceId, idWorkItem
  -->

  <process id="anc_pratica" name="ANC - Gestione Pratica" isExecutable="true">

    <!-- ===== START ===== -->
    <startEvent id="start" name="Pratica Aperta"/>

    <sequenceFlow id="flow_start_to_lavorazione" sourceRef="start" targetRef="task_lavorazione"/>

    <!-- ===== LAVORAZIONE OPERATORE ===== -->
    <userTask id="task_lavorazione" name="Lavorazione Pratica">
      <documentation>
        L'operatore ANC verifica la documentazione, compila la checklist
        e invia la pratica alla conferma BPM.
      </documentation>
      <potentialOwner>
        <resourceAssignmentExpression>
          <formalExpression>group(GRUPPO_OPERATORE_ANC)</formalExpression>
        </resourceAssignmentExpression>
      </potentialOwner>
    </userTask>

    <sequenceFlow id="flow_lavorazione_to_supervisione" sourceRef="task_lavorazione" targetRef="task_supervisione"/>

    <!-- ===== SUPERVISIONE ===== -->
    <userTask id="task_supervisione" name="Supervisione">
      <documentation>
        Il supervisore ANC controlla la pratica lavorata e la approva o respinge.
      </documentation>
      <potentialOwner>
        <resourceAssignmentExpression>
          <formalExpression>group(SUPERVISORE_ANC)</formalExpression>
        </resourceAssignmentExpression>
      </potentialOwner>
    </userTask>

    <!-- Gateway esito supervisione -->
    <sequenceFlow id="flow_supervisione_to_gw" sourceRef="task_supervisione" targetRef="gw_esito"/>

    <exclusiveGateway id="gw_esito" name="Esito Supervisione"/>

    <sequenceFlow id="flow_esito_ok" sourceRef="gw_esito" targetRef="end_ok">
      <conditionExpression xsi:type="tFormalExpression">${esito == 'OK'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_esito_ko" sourceRef="gw_esito" targetRef="end_ko">
      <conditionExpression xsi:type="tFormalExpression">${esito == 'KO'}</conditionExpression>
    </sequenceFlow>

    <!-- ===== END EVENTS ===== -->
    <endEvent id="end_ok" name="Chiusa OK"/>
    <endEvent id="end_ko" name="Chiusa KO"/>

  </process>

</definitions>
